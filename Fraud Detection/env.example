# ============================================================
# Application
# ============================================================
APP_NAME=fraud-detection-api
APP_VERSION=2.1.0
ENVIRONMENT=development            # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# ============================================================
# API Security
# ============================================================
API_SECRET_KEY=your-super-secret-key-change-in-production
API_KEY_HEADER=X-API-Key
ALLOWED_ORIGINS=http://localhost:3000,https://your-powerbi-domain.com

# ============================================================
# Database (PostgreSQL — audit log & predictions store)
# ============================================================
DATABASE_URL=postgresql://fraud_user:fraud_pass@localhost:5432/fraud_db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ============================================================
# Redis (feature caching & rate limiting)
# ============================================================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================
# MLflow
# ============================================================
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fraud-detection-production
MLFLOW_S3_ENDPOINT_URL=https://storage.googleapis.com
MLFLOW_ARTIFACT_ROOT=gs://your-bucket/mlflow-artifacts

# ============================================================
# GCP Configuration
# ============================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=me-central1             # Dubai / Middle East
GCP_BUCKET_NAME=fraud-detection-models
GOOGLE_APPLICATION_CREDENTIALS=/app/service-account.json

# ============================================================
# Model Configuration
# ============================================================
MODEL_VERSION=ensemble-v2.1.0
MODEL_REGISTRY_PATH=gs://your-bucket/models/production
GNN_CHECKPOINT_PATH=/app/checkpoints/graphsage_best.pt
XGBOOST_MODEL_PATH=/app/checkpoints/xgboost_ensemble.pkl
FRAUD_SCORE_THRESHOLD=0.5
HIGH_RISK_THRESHOLD=0.75
CRITICAL_RISK_THRESHOLD=0.90

# ============================================================
# Monitoring & Alerting
# ============================================================
PROMETHEUS_PORT=9090
DRIFT_ALERT_WEBHOOK=https://hooks.slack.com/your-webhook
DRIFT_PSI_THRESHOLD=0.2
MONITORING_WINDOW_HOURS=24

# ============================================================
# UAE Compliance
# ============================================================
COMPLIANCE_JURISDICTION=UAE
CBUAE_REPORTING_ENABLED=true
VARA_EXPLAINABILITY_REQUIRED=true
AUDIT_LOG_RETENTION_DAYS=2555      # 7 years per CBUAE requirement
